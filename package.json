{
  "name": "remix-cloudflare-piano",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "deploy": "npm run build && wrangler deploy",
    "dev": "react-router dev",
    "prebuild": "bun scripts/build_public_pages.ts --require-llm --base-url https://pianobooth.com",
    "build:public": "bun scripts/build_public_pages.ts --require-llm --base-url https://pianobooth.com",
    "record": "bun scripts/render_next_video.ts",
    "record:mobile": "bun scripts/render_next_mobile_video.ts",
    "record:full": "bun scripts/render_next_full_set.ts",
    "pop": "bun scripts/record_category.ts pop",
    "finnish": "bun scripts/record_category.ts finnish",
    "theme": "bun scripts/record_category.ts theme",
    "test": "bun tests/test_websocket_stream.ts",
    "generate:og": "bun scripts/generate_og_images.ts",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "start": "wrangler dev",
    "typecheck": "react-router typegen && tsc",
    "typegen": "wrangler types",
    "preview": "npm run build && wrangler dev",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@mdi/js": "^7.4.47",
    "@mdi/react": "^1.6.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "9",
    "@react-router/cloudflare": "^7.1.1",
    "@tonejs/midi": "^2.0.28",
    "isbot": "^3.6.8",
    "react": "19",
    "react-dom": "19",
    "react-icons": "^5.3.0",
    "react-router": "^7.1.1",
    "soundfont-player": "^0.12.0",
    "three": "^0.160.0",
    "ws": "^8.18.3",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.0.0",
    "@cloudflare/workers-types": "^4.20241106.0",
    "@react-router/dev": "^7.1.1",
    "@react-router/fs-routes": "^7.1.1",
    "@types/react": "19",
    "@types/react-dom": "19",
    "@typescript-eslint/eslint-plugin": "^6.7.4",
    "@typescript-eslint/parser": "^6.7.4",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.38.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "playwright": "^1.54.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.1.6",
    "vite": "^6.1.0",
    "vite-tsconfig-paths": "^4.2.1",
    "wrangler": "^4.54.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
